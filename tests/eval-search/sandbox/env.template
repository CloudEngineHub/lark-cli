# eval-search sandbox executor credentials.
#
# Copy to ~/.eval-search-sandbox.env, then fill these values. The account you
# authorize here must NOT have access to the eval Base.

LARKSUITE_CLI_APP_ID=
LARKSUITE_CLI_APP_SECRET=

# Optional. If set, the sandbox imports this user access token and skips
# device-code login. The token must belong to the isolated executor account.
# LARKSUITE_CLI_USER_ACCESS_TOKEN=

# Optional.
# LARKSUITE_CLI_BRAND=feishu
# EVAL_SEARCH_AUTH_DOMAINS=base,drive,docs,wiki,task,contact,im,minutes,vc,mail,calendar

# Optional guardrails. Set one or both to fail fast when the authorized
# executor is not the eval-set persona.
# EVAL_SEARCH_EXPECTED_EXECUTOR_NAME=搜索-测试张三
# EVAL_SEARCH_EXPECTED_EXECUTOR_OPEN_ID=ou_xxx
